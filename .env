# =============================================================================
# SelfiStar – Environment variables (do not commit this file)
# =============================================================================
# Copy .env.example to .env and fill in your values. Never commit .env to git.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=8080

# Public URL of your app (for invite/share links). No trailing slash.
# Local: http://localhost:8080  |  Production: https://selfie.theglam.world
FRONTEND_URL=https://click.selfiestar.fun

# Optional: message returned by GET /api/ping
PING_MESSAGE=ping

# -----------------------------------------------------------------------------
# Database (MongoDB)
# -----------------------------------------------------------------------------
# Local: mongodb://localhost:27017/selfistar
# Atlas:  mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/DATABASE?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://akashzeen_db_user:akashsharma@selfistar-cluster.5gggbqa.mongodb.net/selfistar?retryWrites=true&w=majority

# -----------------------------------------------------------------------------
# Auth & security (use long random strings in production)
# -----------------------------------------------------------------------------
# Generate: openssl rand -hex 32
JWT_SECRET=3f58eb2ebfc19f4c35679bb0e90e5455ac326467ddd5f1b05314856ca3f8220f

# For signed selfie view URLs. Generate: openssl rand -hex 32
SIGNED_URL_SECRET=8783d47b0f21fdf31346ef8449334f4612868acbc207f456eb754a2c0841d80c

# Hex key for encrypting stored data (64 hex chars = 32 bytes). Generate: openssl rand -hex 32
SELFIE_ENCRYPTION_KEY=8e9b13047ac33ad1b3338c9ff897693cbdadcc31906ac6b2b0b79fb6d468c0f0

# Signed selfie link validity in seconds (default 300 = 5 min)
SELFIE_TOKEN_TTL_SEC=300

# Allowed CORS origin. Use * in dev; set your frontend URL in production.
CORS_ORIGIN=https://click.selfiestar.fun

# -----------------------------------------------------------------------------
# Cloudinary (image uploads)
# -----------------------------------------------------------------------------
# From https://console.cloudinary.com/
CLOUDINARY_CLOUD_NAME=dfebxdvd1
CLOUDINARY_API_KEY=714311551354625
