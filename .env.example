# =============================================================================
# SelfiStar – Environment variables
# =============================================================================
# Copy to .env and fill in values. Never commit .env to git.
# Used by: server (Node), client (Vite embeds VITE_* at build time).
# =============================================================================

# -----------------------------------------------------------------------------
# Server (backend)
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=8080

# Public URL of this app (for share/invite links). No trailing slash.
# Local:    http://localhost:8080
# Railway:  https://your-app.up.railway.app
# Render:    https://your-app.onrender.com
# Netlify:  set this to your Netlify URL when API is on Railway/Render
FRONTEND_URL=http://localhost:8080

# Allowed CORS origin. Use * in dev; in production set to your frontend URL.
# Split deploy (Netlify + Railway): set to your Netlify URL, e.g. https://your-site.netlify.app
CORS_ORIGIN=*

# Optional: response for GET /api/ping
PING_MESSAGE=ping

# -----------------------------------------------------------------------------
# Database (required for persistence)
# -----------------------------------------------------------------------------
# Local:  mongodb://localhost:27017/selfistar
# Atlas:  mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/DATABASE?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/selfistar

# -----------------------------------------------------------------------------
# Auth & security (required in production; use long random strings)
# -----------------------------------------------------------------------------
# Login/session JWT. Generate: openssl rand -hex 32
JWT_SECRET=your-jwt-secret-min-32-chars

# Signed selfie view URLs. Generate: openssl rand -hex 32
SIGNED_URL_SECRET=your-signed-url-secret-min-32-chars

# Encrypt stored selfies. 64 hex chars (32 bytes). Generate: openssl rand -hex 32
SELFIE_ENCRYPTION_KEY=

# Signed selfie link validity in seconds (default 300 = 5 min)
SELFIE_TOKEN_TTL_SEC=300

# -----------------------------------------------------------------------------
# Cloudinary (optional – image uploads)
# -----------------------------------------------------------------------------
# From https://console.cloudinary.com/
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# -----------------------------------------------------------------------------
# Frontend (client) – only when API and frontend are on different hosts
# -----------------------------------------------------------------------------
# Set on Netlify/Vercel when API is on Railway/Render. Full base including /api.
# Example: https://your-app.up.railway.app/api
# Leave unset when frontend and API are same origin (e.g. full stack on Railway).
# VITE_API_URL=

# -----------------------------------------------------------------------------
# mselfistar subscription APIs (login + my account)
# -----------------------------------------------------------------------------
# Base URL for portal subscription APIs
MSELFISTAR_API_BASE=https://mselfistar.com/prod/Selfiestar
# Set to false in local dev to skip subscription checks (default: true in production)
# MSELFISTAR_ENABLED=false

# -----------------------------------------------------------------------------
# Optional (e.g. CMS / Builder.io)
# -----------------------------------------------------------------------------
# VITE_PUBLIC_BUILDER_KEY=
